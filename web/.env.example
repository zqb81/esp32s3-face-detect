# ===== ESP32-S3 人脸检测系统 — 服务端配置 =====
# 复制为 .env 并填入实际值，.env 不会提交到仓库
# ESP32 设备端配置在 main/config.json

# ----- MQTT -----
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883

# ----- Web 服务 (HTTP :8080) -----
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_SECRET_KEY=face_detect_secret
DB_PATH=face_detect.db

# ----- 语音服务 (TCP :9000) -----
TCP_HOST=0.0.0.0
TCP_PORT=9000

# ----- MiMo AI (ASR/LLM/TTS) -----
XIAOMI_API_KEY=your_xiaomi_mimo_api_key_here
