# ===== ESP32-S3 人脸检测系统 — 环境配置 =====
# 复制此文件为 .env 并填入实际值
# .env 已在 .gitignore 中排除，不会提交到仓库

# ----- ESP32 设备端 (main/main.py) -----
WIFI_SSID=你的WiFi名
WIFI_PASS=你的WiFi密码
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
VOICE_SERVER_IP=127.0.0.1
VOICE_SERVER_PORT=9000

# ----- Web 服务端 (web/app.py) -----
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_SECRET_KEY=face_detect_secret
DB_PATH=face_detect.db

# ----- 语音服务端 (web/voice_server.py) -----
TCP_HOST=0.0.0.0
TCP_PORT=9000
XIAOMI_API_KEY=your_xiaomi_mimo_api_key_here
